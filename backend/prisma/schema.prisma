generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserStatus {
  ACTIVE
  INACTIVE
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
}

enum UserLevel {
  COMPANY
  ORG
}

enum RoleType {
  COMPANY
  ORG
}

model Company {
  id        Int        @id @default(autoincrement())
  name      String
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model User {
  id        Int        @id @default(autoincrement())
  username  String     @unique
  password  String
  firstName String
  lastName  String
  mobile    String
  status    UserStatus @default(ACTIVE)
  userLevel UserLevel

  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  userRoles UserRole[]
  approvals Approval[]
  createdRequests Request[] @relation("RequestCreator")
}

model Role {
  id       Int      @id @default(autoincrement())
  name     String
  type     RoleType

  orgId    Int?            // null for COMPANY roles, set for ORG roles
  org      Organization?   @relation(fields: [orgId], references: [id])

  userRoles UserRole[]

  @@unique([name, orgId]) // same role name can exist in different orgs
}

model UserRole {
  id        Int      @id @default(autoincrement())
  userId    Int
  roleId    Int

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

model Patient {
  id          Int       @id @default(autoincrement())
  regDate     DateTime?
  uhidNo      String?
  patientName String
  address1    String?
  age         Int?
  bloodGroup  String?
  mobileNo    String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([uhidNo], map: "Patient_uhidNo_key")
}

model Doctor {
  id        Int      @id @default(autoincrement())
  name      String
  degree    String
  descName  String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Organization {
  id        Int        @id @default(autoincrement())
  name      String
  status    OrgStatus  @default(ACTIVE)
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  roles     Role[]
  requests  Request[]
}

enum OrgStatus {
  ACTIVE
  INACTIVE
}

model Request {
  id          Int            @id @default(autoincrement())
  orgId       Int
  title       String
  description String?
  status      ApprovalStatus @default(PENDING)
  createdBy   Int
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  creator      User         @relation("RequestCreator", fields: [createdBy], references: [id])
  approvals    Approval[]

  @@index([orgId])
  @@index([createdBy])
}

model Approval {
  id         Int            @id @default(autoincrement())
  requestId   Int
  approverId Int
  approvalRoleId Int?       // which role approved (optional)
  status     ApprovalStatus @default(PENDING)
  comment    String?
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  request    Request        @relation(fields: [requestId], references: [id], onDelete: Cascade)
  approver   User           @relation(fields: [approverId], references: [id], onDelete: Cascade)

  @@unique([requestId, approverId])
  @@index([approverId])
}
